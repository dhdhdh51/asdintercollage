# Minimal bootstrap .env — all real config lives in config/local.php
# The web installer (public/install.php) creates config/local.php automatically.
APP_ENV=production
APP_DEBUG=false
APP_KEY=

LOG_CHANNEL=stack
LOG_LEVEL=error

SESSION_DRIVER=file
QUEUE_CONNECTION=sync
CACHE_STORE=file
FILESYSTEM_DISK=local
